# Default: detect text files and normalize to LF on commit, check out as LF.
# This eliminates CRLF/LF noise when contributors work across Windows/macOS/Linux/WSL.
* text=auto eol=lf

# Source code
*.rs        text eol=lf
*.swift     text eol=lf
*.nix       text eol=lf

# Configuration / manifests
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.lock      text eol=lf
Cargo.lock  text eol=lf

# Documentation
*.md        text eol=lf
LICENSE     text eol=lf

# Shell / dotfiles
*.sh        text eol=lf
.envrc      text eol=lf
.gitignore  text eol=lf

# Xcode project files (XML-based plain text)
*.pbxproj           text eol=lf
*.xcworkspacedata   text eol=lf
*.xcscheme          text eol=lf
*.plist             text eol=lf
*.entitlements      text eol=lf
*.xml               text eol=lf

# Generated diff hygiene: mark Cargo.lock as generated so GitHub collapses it in PRs.
Cargo.lock  linguist-generated=true

# Binary assets — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.nv12      binary
*.yuv       binary
*.mjpeg     binary
*.mp4       binary
*.webm      binary
*.xcuserstate   binary
.DS_Store   binary
